---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const GITHUB = 'https://github.com/spronta/crawlie';
---
<BaseLayout
  title="404 — page not found · crawlie"
  description="That page wandered off the crawl. The URL you followed doesn't exist or has moved."
  canonical="/404"
>
  <SiteHeader />

  <main class="notfound">
    <div class="container inner">
      <pre class="ascii" aria-hidden="true"> _  _    ___   _  _
| || |  / _ \ | || |
| || |_| | | || || |_
|__   _| |_| ||__   _|
   |_|  \___/    |_|   <span class="cursor">█</span></pre>

      <h1>This page wandered off the crawl.</h1>
      <p class="lede">
        The URL you followed doesn't exist — or it moved. Even crawlie flags this
        one; it's the most famous status code on the web.
      </p>

      <div class="issue" role="img" aria-label="Audit finding: broken link returning 404">
        <span class="sev">E</span>
        <span class="rule">broken-link</span>
        <span class="arrow">{`this page  →  404 Not Found`}</span>
      </div>

      <div class="actions">
        <a href="/" class="btn btn-primary">← Back to home</a>
        <a href="/docs/getting-started" class="btn btn-ghost">Read the docs</a>
      </div>

      <nav class="suggest" aria-label="Helpful links">
        <a href="/docs/getting-started">Getting started</a>
        <span>·</span>
        <a href="/docs/cli">CLI</a>
        <span>·</span>
        <a href="/changelog">Changelog</a>
        <span>·</span>
        <a href={GITHUB} target="_blank" rel="noopener">GitHub</a>
      </nav>
    </div>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .notfound {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 60px);
    padding: 64px 0;
    overflow: hidden;
  }
  /* Soft brand glow behind the ascii. */
  .notfound::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      520px 320px at 50% 38%,
      color-mix(in srgb, var(--blue) 18%, transparent),
      transparent 70%
    );
    pointer-events: none;
  }
  .inner {
    position: relative;
    text-align: center;
    max-width: 640px;
  }

  .ascii {
    display: inline-block;
    margin: 0 auto 8px;
    font-family: var(--font-mono);
    font-size: clamp(13px, 3.4vw, 22px);
    line-height: 1.05;
    text-align: left;
    color: var(--blue);
    text-shadow: 0 0 22px color-mix(in srgb, var(--blue) 55%, transparent);
    white-space: pre;
    background: none;
    border: 0;
    padding: 0;
  }
  .cursor {
    color: var(--green);
    animation: blink 1.1s step-end infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  .inner h1 {
    font-size: clamp(24px, 4vw, 34px);
    letter-spacing: -0.02em;
    margin: 18px 0 12px;
  }
  .lede {
    color: var(--muted);
    font-size: 17px;
    line-height: 1.55;
    margin: 0 auto 26px;
    max-width: 46ch;
  }

  /* A crawlie-style audit row — the page auditing itself. */
  .issue {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 13.5px;
    padding: 9px 14px;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-sm);
    background: var(--panel);
    color: var(--muted);
    margin-bottom: 30px;
  }
  .issue .sev {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 5px;
    background: color-mix(in srgb, var(--red) 16%, transparent);
    color: var(--red);
    font-weight: 700;
    font-size: 12px;
  }
  .issue .rule { color: var(--text); }
  .issue .arrow { color: var(--muted-2); }

  .actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 26px;
  }

  .suggest {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
    font-size: 14px;
    color: var(--muted-2);
  }
  .suggest a { color: var(--muted); }
  .suggest a:hover { color: var(--text); }

  @media (max-width: 520px) {
    .issue { font-size: 12px; gap: 8px; padding: 8px 10px; }
  }
</style>
