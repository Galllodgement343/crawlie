---
import { formatStars } from '../lib/github';

interface Props {
  href: string;
  stars: number | null;
  class?: string;
}
const { href, stars, class: cls = '' } = Astro.props;
const starLabel = formatStars(stars);
---
<a href={href} class={`btn btn-ghost gh-star-btn ${cls}`} target="_blank" rel="noopener">
  <svg class="gh-logo" viewBox="0 0 16 16" width="17" height="17" aria-hidden="true" fill="currentColor">
    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
  </svg>
  <span>Star on GitHub</span>
  {starLabel && (
    <span class="gh-count">
      <svg class="gh-star" viewBox="0 0 16 16" width="12" height="12" aria-hidden="true" fill="currentColor">
        <path d="M8 .25l2.06 4.18 4.61.67-3.34 3.25.79 4.6L8 11.6l-4.12 2.17.79-4.6L1.33 5.1l4.61-.67L8 .25z"/>
      </svg>
      {starLabel}
    </span>
  )}
</a>

<style>
  .gh-star-btn { gap: 9px; }
  .gh-logo { flex: none; }
  .gh-count {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    margin-left: 2px;
    padding: 2px 8px;
    font-size: 13px;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 999px;
  }
  .gh-star-btn:hover .gh-count { color: var(--text); }
</style>
